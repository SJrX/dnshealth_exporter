*.test
*.out
dnshealth_exporter
dist/
cache/

# Editor / OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db

# Git
.git/
.gitignore

# Demo's own files (the Dockerfile only needs the Go module — not the
# Compose stack that wraps it)
demo/
