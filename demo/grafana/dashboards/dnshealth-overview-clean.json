{
  "uid": "dnshealth-overview-clean",
  "title": "DNS Health Overview (clean)",
  "tags": [
    "dnshealth"
  ],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 0,
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "fiscalYearStartMonth": 0,
  "refresh": "10s",
  "schemaVersion": 41,
  "panels": [
    {
      "type": "table",
      "targets": [
        {
          "expr": "(count by (zone) (dnshealth_ns_record{source=\"parent\",zone=\"$zone\"}) \u003e bool 0) or on() vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "Parent has NS records for the zone",
          "refId": "A"
        }
      ],
      "title": "Parent — status",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "repeatDirection": "h",
      "transformations": [
        {
          "id": "reduce",
          "options": {
            "reducers": [
              "last"
            ],
            "mode": "seriesToRows"
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Field": "Test",
              "Last": "Result"
            },
            "indexByName": {
              "Field": 0,
              "Last": 1
            }
          }
        }
      ],
      "options": {
        "frameIndex": 0,
        "showHeader": true,
        "showTypeIcons": false,
        "footer": {
          "show": false,
          "reducer": null,
          "countRows": false
        },
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Test"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 260
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Result"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": {
                        "color": "red",
                        "index": 0,
                        "text": "FAIL"
                      },
                      "1": {
                        "color": "green",
                        "index": 1,
                        "text": "PASS"
                      }
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "basic",
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "table",
      "targets": [
        {
          "expr": "(count by (zone) (count by (zone, nameserver) (dnshealth_query_success{check=\"soa\",zone=\"$zone\"})) \u003e= bool 2) or on() vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "Multiple authoritative nameservers (\u003e=2)",
          "refId": "A"
        },
        {
          "expr": "min by (zone) (dnshealth_query_success{check=\"soa\",zone=\"$zone\"}) or on() vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "All NSs answered SOA authoritatively",
          "refId": "B"
        },
        {
          "expr": "(max by (zone) (dnshealth_ns_recursion_available{zone=\"$zone\"}) == bool 0) or on() vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "No NS advertises recursion (RA=0)",
          "refId": "C"
        },
        {
          "expr": "((count by (zone) (group by (zone, nameserver) (dnshealth_ns_record{source=\"parent\",zone=\"$zone\"}))) == bool (count by (zone) (group by (zone, nameserver) (dnshealth_ns_record{source=\"self\",zone=\"$zone\"})))) and on(zone) (count by (zone) (dnshealth_ns_record{source=\"self\",zone=\"$zone\"}) \u003e bool 0) or on() vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "Parent and self report same NS records",
          "refId": "D"
        }
      ],
      "title": "NS — status",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "repeatDirection": "h",
      "transformations": [
        {
          "id": "reduce",
          "options": {
            "reducers": [
              "last"
            ],
            "mode": "seriesToRows"
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Field": "Test",
              "Last": "Result"
            },
            "indexByName": {
              "Field": 0,
              "Last": 1
            }
          }
        }
      ],
      "options": {
        "frameIndex": 0,
        "showHeader": true,
        "showTypeIcons": false,
        "footer": {
          "show": false,
          "reducer": null,
          "countRows": false
        },
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Test"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 280
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Result"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": {
                        "color": "red",
                        "index": 0,
                        "text": "FAIL"
                      },
                      "1": {
                        "color": "green",
                        "index": 1,
                        "text": "PASS"
                      }
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "basic",
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "table",
      "targets": [
        {
          "expr": "((max by (zone) (dnshealth_soa_serial{zone=\"$zone\"}) - min by (zone) (dnshealth_soa_serial{zone=\"$zone\"})) == bool 0) and on(zone) (count by (zone) (dnshealth_soa_serial{zone=\"$zone\"}) \u003e bool 0) or on() vector(0)",
          "instant": true,
          "range": false,
          "legendFormat": "All NSs report same SOA serial",
          "refId": "A"
        }
      ],
      "title": "SOA — status",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "repeatDirection": "h",
      "transformations": [
        {
          "id": "reduce",
          "options": {
            "reducers": [
              "last"
            ],
            "mode": "seriesToRows"
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Field": "Test",
              "Last": "Result"
            },
            "indexByName": {
              "Field": 0,
              "Last": 1
            }
          }
        }
      ],
      "options": {
        "frameIndex": 0,
        "showHeader": true,
        "showTypeIcons": false,
        "footer": {
          "show": false,
          "reducer": null,
          "countRows": false
        },
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Test"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 260
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Result"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": {
                        "color": "red",
                        "index": 0,
                        "text": "FAIL"
                      },
                      "1": {
                        "color": "green",
                        "index": 1,
                        "text": "PASS"
                      }
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "basic",
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "table",
      "targets": [
        {
          "expr": "dnshealth_ns_record{source=\"parent\",zone=\"$zone\"}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "A"
        }
      ],
      "title": "NS records — from parent",
      "description": "What the parent referral lists as the zone's NSs. Glue IP empty = parent did not include A glue (exporter resolved separately).",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus}"
      },
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "repeatDirection": "h",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "ip": "Glue IP",
              "nameserver": "Nameserver"
            },
            "indexByName": {
              "ip": 1,
              "nameserver": 0
            },
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "source": true,
              "zone": true
            }
          }
        }
      ],
      "options": {
        "frameIndex": 0,
        "showHeader": true,
        "showTypeIcons": false,
        "footer": {
          "show": false,
          "reducer": null,
          "countRows": false
        },
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Glue IP"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "": {
                        "color": "text",
                        "index": 0,
                        "text": "(not provided)"
                      }
                    },
                    "type": "value"
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "type": "table",
      "targets": [
        {
          "expr": "dnshealth_ns_record{source=\"self\",zone=\"$zone\"}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "A"
        },
        {
          "expr": "dnshealth_query_success{check=\"soa\",zone=\"$zone\"}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "B"
        },
        {
          "expr": "dnshealth_ns_recursion_available{zone=\"$zone\"}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "C"
        }
      ],
      "title": "NS records — from the zone",
      "description": "What the auth servers themselves report as the zone's NSs (source=\"self\" rows from the glue prober), joined with each NS's probe response (Responded = SOA query succeeded, Recursion = RA flag set). Empty Responded/Recursion cells mean the exporter has no probe data for that NS — happens when the auth's self-reported NS list does not match what the parent advertised, since SOA/recursion checks only run against parent-listed NSs.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus}"
      },
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "repeatDirection": "h",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "nameserver",
            "mode": "outer"
          }
        },
        {
          "id": "filterByValue",
          "options": {
            "filters": [
              {
                "fieldName": "Value #A",
                "config": {
                  "id": "isNotNull",
                  "options": {}
                }
              }
            ],
            "type": "include",
            "match": "all"
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #B": "Responded",
              "Value #C": "Recursion",
              "ip 1": "IP"
            },
            "indexByName": {
              "Value #B": 2,
              "Value #C": 3,
              "ip 1": 1,
              "nameserver": 0
            },
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Value #A": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "__name__ 3": true,
              "check": true,
              "instance 1": true,
              "instance 2": true,
              "instance 3": true,
              "ip 2": true,
              "ip 3": true,
              "job 1": true,
              "job 2": true,
              "job 3": true,
              "source 1": true,
              "zone 1": true,
              "zone 2": true,
              "zone 3": true
            }
          }
        }
      ],
      "options": {
        "frameIndex": 0,
        "showHeader": true,
        "showTypeIcons": false,
        "footer": {
          "show": false,
          "reducer": null,
          "countRows": false
        },
        "cellHeight": "sm"
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Responded"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": {
                        "color": "red",
                        "index": 0,
                        "text": "no"
                      },
                      "1": {
                        "color": "green",
                        "index": 1,
                        "text": "yes"
                      }
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "basic",
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Recursion"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": {
                        "color": "green",
                        "index": 0,
                        "text": "no"
                      },
                      "1": {
                        "color": "red",
                        "index": 1,
                        "text": "RA=1"
                      }
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "basic",
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "type": "table",
      "targets": [
        {
          "expr": "dnshealth_soa_serial{zone=\"$zone\"}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "A"
        },
        {
          "expr": "dnshealth_soa_refresh_seconds{zone=\"$zone\"}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "B"
        },
        {
          "expr": "dnshealth_soa_retry_seconds{zone=\"$zone\"}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "C"
        },
        {
          "expr": "dnshealth_soa_expire_seconds{zone=\"$zone\"}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "D"
        },
        {
          "expr": "dnshealth_soa_minimum_seconds{zone=\"$zone\"}",
          "instant": true,
          "range": false,
          "format": "table",
          "refId": "E"
        }
      ],
      "title": "SOA — per-nameserver values",
      "description": "One row per nameserver. Empty/missing rows mean the SOA query failed for that NS.",
      "transparent": false,
      "datasource": {
        "type": "prometheus",
        "uid": "${prometheus}"
      },
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "repeatDirection": "h",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "nameserver",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "Value #A": "Serial",
              "Value #B": "Refresh (s)",
              "Value #C": "Retry (s)",
              "Value #D": "Expire (s)",
              "Value #E": "Min TTL (s)",
              "ip 1": "IP"
            },
            "indexByName": {
              "Value #A": 2,
              "Value #B": 3,
              "Value #C": 4,
              "Value #D": 5,
              "Value #E": 6,
              "ip 1": 1,
              "nameserver": 0
            },
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "Time 5": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "__name__ 3": true,
              "__name__ 4": true,
              "__name__ 5": true,
              "instance 1": true,
              "instance 2": true,
              "instance 3": true,
              "instance 4": true,
              "instance 5": true,
              "ip 2": true,
              "ip 3": true,
              "ip 4": true,
              "ip 5": true,
              "job 1": true,
              "job 2": true,
              "job 3": true,
              "job 4": true,
              "job 5": true,
              "zone 1": true,
              "zone 2": true,
              "zone 3": true,
              "zone 4": true,
              "zone 5": true
            }
          }
        }
      ],
      "options": {
        "frameIndex": 0,
        "showHeader": true,
        "showTypeIcons": false,
        "footer": {
          "show": false,
          "reducer": null,
          "countRows": false
        },
        "cellHeight": "sm"
      }
    },
    {
      "type": "row",
      "collapsed": true,
      "title": "Operator / debug views",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "id": 0,
      "panels": [
        {
          "type": "timeseries",
          "targets": [
            {
              "expr": "dnshealth_probe_cycle_duration_seconds",
              "legendFormat": "cycle duration",
              "refId": "A"
            }
          ],
          "title": "Probe cycle duration",
          "description": "Wall time of each probe cycle, from dnshealth_probe_cycle_duration_seconds.",
          "transparent": false,
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus}"
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 19
          },
          "repeatDirection": "h",
          "options": {
            "legend": {
              "displayMode": "list",
              "placement": "bottom",
              "showLegend": true,
              "calcs": []
            },
            "tooltip": {
              "mode": "single",
              "sort": "none"
            }
          },
          "fieldConfig": {
            "defaults": {
              "unit": "s",
              "color": {
                "mode": "palette-classic"
              }
            },
            "overrides": []
          }
        },
        {
          "type": "timeseries",
          "targets": [
            {
              "expr": "rate(dnshealth_dns_queries_total[1m])",
              "legendFormat": "queries/s — {{server}}",
              "refId": "A"
            },
            {
              "expr": "rate(dnshealth_delegation_cache_hits_total[5m]) / clamp_min((rate(dnshealth_delegation_cache_hits_total[5m]) + rate(dnshealth_delegation_cache_misses_total[5m])), 1e-9)",
              "legendFormat": "cache hit ratio",
              "refId": "B"
            }
          ],
          "title": "Query rate and delegation cache hit ratio",
          "description": "Left axis: per-server query rate. Cache ratio = hits / (hits + misses).",
          "transparent": false,
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus}"
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 19
          },
          "repeatDirection": "h",
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "showLegend": true,
              "calcs": [
                "mean"
              ]
            },
            "tooltip": {
              "mode": "multi",
              "sort": "none"
            }
          },
          "fieldConfig": {
            "defaults": {
              "color": {
                "mode": "palette-classic"
              }
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byName",
                  "options": "cache hit ratio"
                },
                "properties": [
                  {
                    "id": "unit",
                    "value": "percentunit"
                  },
                  {
                    "id": "custom.axisPlacement",
                    "value": "right"
                  }
                ]
              }
            ]
          }
        },
        {
          "type": "timeseries",
          "targets": [
            {
              "expr": "dnshealth_soa_serial{zone=\"$zone\"}",
              "legendFormat": "{{nameserver}}",
              "refId": "A"
            }
          ],
          "title": "SOA serials per nameserver over time — ${zone}",
          "description": "Each line is one nameserver for the selected zone. Lines overlap when primaries agree; divergence appears as parallel non-overlapping lines.",
          "transparent": false,
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus}"
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 27
          },
          "repeatDirection": "h",
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "showLegend": true,
              "calcs": [
                "lastNotNull"
              ]
            },
            "tooltip": {
              "mode": "multi",
              "sort": "none"
            }
          },
          "fieldConfig": {
            "defaults": {
              "color": {
                "mode": "palette-classic"
              },
              "custom": {
                "lineInterpolation": "stepAfter",
                "showPoints": "always"
              }
            },
            "overrides": []
          }
        },
        {
          "type": "timeseries",
          "targets": [
            {
              "expr": "dnshealth_query_duration_seconds{zone=\"$zone\"}",
              "legendFormat": "{{check}} via {{nameserver}}",
              "refId": "A"
            }
          ],
          "title": "Query duration (per check / nameserver) — ${zone}",
          "description": "dnshealth_query_duration_seconds for the selected zone — useful for spotting slow nameservers or check types.",
          "transparent": false,
          "datasource": {
            "type": "prometheus",
            "uid": "${prometheus}"
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 27
          },
          "repeatDirection": "h",
          "options": {
            "legend": {
              "displayMode": "table",
              "placement": "bottom",
              "showLegend": true,
              "calcs": [
                "max"
              ]
            },
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            }
          },
