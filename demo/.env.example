# Demo port overrides. Copy this file to `.env` and edit any value
# that conflicts with something already running on your host:
#
#   cp .env.example .env
#   $EDITOR .env
#   docker compose up -d
#
# Compose reads `.env` automatically. The `${VAR:-default}` syntax in
# docker-compose.yml falls back to the default when the variable is
# unset, so leaving any line commented out is safe.

GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
EXPORTER_PORT=9266
